          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Producto protegido\",\n  \"price\": 12.5\n}"
        },
        "url": {
          "raw": "http://localhost:3000/products",
          "host": ["http://localhost:3000"],
          "path": ["products"]
        }
      }
    },
