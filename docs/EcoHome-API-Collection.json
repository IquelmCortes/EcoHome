  },
  "item": [
    {
      "name": "Auth - Signup",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Usuario Prueba\",\n  \"username\": \"usuarioprueba\",\n  \"email\": \"prueba@ecohome.com\",\n  \"password\": \"123456\",\n  \"role\": \"client\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/auth/signup",
          "host": ["http://localhost:3000"],
          "path": ["auth", "signup"]
        }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"prueba@ecohome.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/auth/login",
          "host": ["http://localhost:3000"],
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "Products - List all",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:3000/products",
          "host": ["http://localhost:3000"],
          "path": ["products"]
        }
      }
    },
    {
      "name": "Products - Get by id",
      "request": {
        "method": "GET",
